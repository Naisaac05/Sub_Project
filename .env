# ========================================
# DATABASE SETTINGS
# ========================================
# MySQL 데이터베이스 로컬 접속 비밀번호
DB_PASSWORD=root

# ========================================
# JWT AUTHENTICATION
# ========================================
# 토큰 암호화를 위한 256-bit 이상 시크릿 키 
JWT_SECRET=devmatch_super_secret_jwt_key_that_is_long_enough

# ========================================
# TOSS PAYMENTS (토스 페이먼츠)
# ========================================
# 토스 개발자 센터 연동 키 (데모/테스트용)
TOSS_CLIENT_KEY=test_gck_docs_Ovk5rk1EwkEbP0W43n07xlzm
TOSS_SECRET_KEY=test_sk_your_secret_key_here

# ========================================
# GOOGLE OAUTH2 (소셜 로그인)
# ========================================
# 발급받은 구글 클라이언트 ID 및 SECRET
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# 구글 캘린더 연동용
GOOGLE_CREDENTIALS_PATH=classpath:google-credentials.json
