# =====================================================================
# .env.prod.example — DevMatch 운영 환경변수 템플릿
# 사용: 서버에서 .env.prod 로 복사 후 실제 값 입력. git 커밋 금지.
#   cp .env.prod.example .env.prod
# (토폴로지성 주소(REDIS_HOST, PYTHON_AI_BASE_URL 등)는 docker-compose.prod.yml 에 있음)
# =====================================================================

# --- 보안/인증 ---
JWT_SECRET=                       # 256bit 이상 (예: openssl rand -base64 48)
AI_REVIEW_SERVICE_TOKEN=          # 백엔드↔AI 공유 토큰(랜덤)

# --- DB (RDS MySQL) ---
DB_HOST=                          # RDS 엔드포인트 호스트(:3306 제외)
DB_USERNAME=devmatch_admin
DB_PASSWORD=
# 스키마 초기화: 최초 1회만 update 로 생성(+시드) 후, 이후 validate 로 되돌릴 것
JPA_DDL_AUTO=validate

# --- CORS (배포 도메인) ---
APP_CORS_ALLOWED_ORIGINS=https://devmatch.duckdns.org

# --- 결제 (test 키 유지 / 실호출 차단 정책) ---
TOSS_CANCEL_ENABLED=false
TOSS_SECRET_KEY=test_sk_xxx
TOSS_CLIENT_KEY=test_gck_xxx

# --- AI 모델 ---
PYTHON_AI_MODEL=exaone3.5:2.4b
PYTHON_AI_FALLBACK_MODEL=exaone3.5:2.4b
OLLAMA_MODEL=exaone3.5:2.4b
AI_REVIEW_EMBEDDING_MODEL=bge-m3

# --- AI 서버 prod 필수값 (production_config 검증) ---
AI_REVIEW_CANDIDATE_SINK=http     # jsonl 금지(컨테이너 재시작 시 유실)
OLLAMA_REQUEST_TIMEOUT_SECONDS=60
OLLAMA_QUEUE_WAIT_TIMEOUT_SECONDS=30
AI_REVIEW_CANDIDATE_CAPTURE_TIMEOUT_SECONDS=10
PYTHON_AI_MAX_TOKENS=256
PYTHON_AI_NUM_CTX=1024
AI_REVIEW_MAX_USER_ANSWER_LENGTH=700
# prod 검증기가 candidates-path 가 .jsonl 이면 거부함 → 빈 값으로 비활성화(후보는 HTTP sink 경유)
AI_REVIEW_CANDIDATES_PATH=
AI_REVIEW_AUTO_CANDIDATES_PATH=

# (구글 로그인/캘린더 제외 — GOOGLE_* 불필요. 캘린더는 자동 스텁 모드)
