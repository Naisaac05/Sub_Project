# =====================================================
# .env.example — 프로젝트 환경변수 템플릿
#
# 사용법: 본 파일을 .env 로 복사 후 본인 환경에 맞게 값 입력
#   cp .env.example .env
#
# .env 는 .gitignore 에 포함되어 있어 커밋되지 않음.
# =====================================================

# 🧪 테스트 전용: AI 리뷰 세션 초기화 기능
#
# 운영 환경에서는 절대 true 로 설정하지 말 것.
# true 로 설정 시 학생이 자신의 AI 리뷰 세션을 초기화하는 엔드포인트가 활성화됨.
# 자세한 내용: docs/superpowers/specs/2026-05-27-ai-review-test-session-reset-design.md
AI_REVIEW_TEST_RESET_ENABLED=false
NEXT_PUBLIC_AI_REVIEW_TEST_RESET=false
